generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  admin
  account_manager
  operations
  customer
}

enum UserStatus {
  active
  pending
  suspended
}

enum ArtworkStatus {
  available
  rented
  reserved
  maintenance
}

enum ArtworkCategory {
  painting
  sculpture
  photography
  mixed_media
  installation
}

enum SubscriptionStatus {
  active
  paused
  cancelled
  past_due
  trial
}

enum InvoiceStatus {
  draft
  issued
  paid
  failed
  cancelled
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum ContractStatus {
  draft
  sent
  signed
  expired
  cancelled
}

enum LeadStatus {
  new
  contacted
  proposal_sent
  negotiation
  won
  lost
}

enum TicketStatus {
  open
  in_progress
  waiting
  resolved
  closed
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

enum NotificationType {
  email
  in_app
  sms
}

enum NotificationCategory {
  billing
  contract
  crm
  support
  system
}

enum ActivityType {
  call
  email
  meeting
  note
  task
}

model User {
  id                   String           @id @default(uuid())
  email                String           @unique
  passwordHash         String
  firstName            String
  lastName             String
  phone                String?
  role                 Role             @relation(fields: [roleId], references: [id])
  roleId               String
  status               UserStatus       @default(active)
  twoFactorEnabled     Boolean          @default(false)
  twoFactorSecret      String?
  lastLoginAt          DateTime?
  lastLoginIp          String?
  subscriptions        Subscription[]
  invoices             Invoice[]
  payments             Payment[]
  contracts            Contract[]
  crmLeads             CrmLead[]        @relation("LeadOwner")
  crmLeadsCustomer     CrmLead[]        @relation("LeadCustomer")
  crmActivities        CrmActivity[]
  supportTickets       SupportTicket[]
  assignedTickets      SupportTicket[]  @relation("TicketAssignee")
  refreshTokens        RefreshToken[]
  notifications        Notification[]
  swapRequests         SwapRequest[]
  activityLogs         ActivityLog[]
  ownedArtworks        Artwork[]        @relation("ArtworkOwner")
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  deletedAt            DateTime?
}

model Role {
  id          String          @id @default(uuid())
  name        RoleName        @unique
  description String?
  isAdmin     Boolean         @default(false)
  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  group       String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model RefreshToken {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  token      String   @unique
  revoked    Boolean  @default(false)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([revoked])
}

model Warehouse {
  id          String     @id @default(uuid())
  name        String
  address     String
  city        String
  state       String
  country     String
  contactName String?
  contactPhone String?
  capacity    Int?
  artworks    Artwork[]
  swapRequestsCurrent   SwapRequest[]  @relation("CurrentWarehouse")
  swapRequestsRequested SwapRequest[]  @relation("RequestedWarehouse")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?
}

model Artwork {
  id               String           @id @default(uuid())
  sku              String           @unique
  title            String
  description      String
  artist           String?
  style            String?
  medium           String?
  yearCreated      Int?
  dimensions       String?
  category         ArtworkCategory
  status           ArtworkStatus    @default(available)
  warehouse        Warehouse?       @relation(fields: [warehouseId], references: [id])
  warehouseId      String?
  owner            User?            @relation("ArtworkOwner", fields: [ownerId], references: [id])
  ownerId          String?
  rentalPriceCents Int
  replacementValue Int
  metadata         Json?            @db.JsonB
  images           ArtworkImage[]
  swapRequests     SwapRequest[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  @@index([status])
  @@index([warehouseId])
  @@index([ownerId])
  @@index([category])
}

model ArtworkImage {
  id         String   @id @default(uuid())
  artwork    Artwork  @relation(fields: [artworkId], references: [id])
  artworkId  String
  fileKey    String
  variant    String
  mimeType   String
  width      Int?
  height     Int?
  order      Int       @default(0)
  isSecure   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?
}

model Subscription {
  id                     String              @id @default(uuid())
  customer               User                @relation(fields: [customerId], references: [id])
  customerId             String
  planName               String
  razorpaySubscriptionId String?             @unique
  status                 SubscriptionStatus  @default(active)
  startDate              DateTime
  nextBillingDate        DateTime
  billingCycle           String
  amountCents            Int
  currency               String              @default("INR")
  gstPercentage          Float               @default(18.0)
  metadata               Json?               @db.JsonB
  invoices               Invoice[]
  payments               Payment[]
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  deletedAt              DateTime?

  @@index([customerId])
  @@index([status])
  @@index([nextBillingDate])
}

model Invoice {
  id                String        @id @default(uuid())
  subscription      Subscription  @relation(fields: [subscriptionId], references: [id])
  subscriptionId    String
  customer          User          @relation(fields: [customerId], references: [id])
  customerId        String
  razorpayInvoiceId String?       @unique
  status            InvoiceStatus @default(draft)
  issueDate         DateTime
  dueDate           DateTime
  paidDate          DateTime?
  amountCents       Int
  taxCents          Int
  totalCents        Int
  gstRate           Float
  invoiceData       Json?         @db.JsonB
  payments          Payment[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
}

model Payment {
  id                 String        @id @default(uuid())
  invoice            Invoice       @relation(fields: [invoiceId], references: [id])
  invoiceId          String
  subscription       Subscription  @relation(fields: [subscriptionId], references: [id])
  subscriptionId     String
  customer           User          @relation(fields: [customerId], references: [id])
  customerId         String
  razorpayPaymentId  String?       @unique
  status             PaymentStatus @default(pending)
  amountCents        Int
  currency           String        @default("INR")
  paymentMethod      String?
  gatewayResponse    Json?         @db.JsonB
  processedAt        DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
}

model Contract {
  id              String         @id @default(uuid())
  customer        User           @relation(fields: [customerId], references: [id])
  customerId      String
  templateId      String
  zohoDocumentId  String?        @unique
  status          ContractStatus @default(draft)
  startDate       DateTime
  endDate         DateTime
  renewalDate     DateTime?
  contractData    Json?          @db.JsonB
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?
}

model CrmLead {
  id                 String       @id @default(uuid())
  owner              User         @relation("LeadOwner", fields: [ownerId], references: [id])
  ownerId            String
  customer           User?        @relation("LeadCustomer", fields: [customerId], references: [id])
  customerId         String?
  status             LeadStatus   @default(new)
  source             String
  companyName        String?
  contactName        String
  email              String
  phone              String?
  estimatedValueCents Int?
  pipelineStage      String?
  nextFollowUpAt     DateTime?
  metadata           Json?        @db.JsonB
  activities         CrmActivity[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  deletedAt          DateTime?

  @@index([ownerId])
  @@index([status])
  @@index([nextFollowUpAt])
}

model CrmActivity {
  id           String       @id @default(uuid())
  lead         CrmLead      @relation(fields: [leadId], references: [id])
  leadId       String
  user         User         @relation(fields: [userId], references: [id])
  userId       String
  activityType ActivityType
  summary      String
  happenedAt   DateTime
  details      Json?        @db.JsonB
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?
}

model SupportTicket {
  id          String        @id @default(uuid())
  customer    User          @relation(fields: [customerId], references: [id])
  customerId  String
  assignedTo  User?         @relation("TicketAssignee", fields: [assignedToId], references: [id])
  assignedToId String?
  status      TicketStatus  @default(open)
  priority    TicketPriority @default(medium)
  subject     String
  description String
  resolution  String?
  closedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
}

model Notification {
  id          String              @id @default(uuid())
  user        User                @relation(fields: [userId], references: [id])
  userId      String
  type        NotificationType
  category    NotificationCategory
  payload     Json?               @db.JsonB
  isRead      Boolean             @default(false)
  sentAt      DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
}

model SwapRequest {
  id                 String        @id @default(uuid())
  customer           User          @relation(fields: [customerId], references: [id])
  customerId         String
  artwork            Artwork       @relation(fields: [artworkId], references: [id])
  artworkId          String
  currentWarehouse   Warehouse     @relation("CurrentWarehouse", fields: [currentWarehouseId], references: [id])
  currentWarehouseId String
  requestedWarehouse Warehouse     @relation("RequestedWarehouse", fields: [requestedWarehouseId], references: [id])
  requestedWarehouseId String
  status             String        @default("requested")
  requestedAt        DateTime      @default(now())
  completedAt        DateTime?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  deletedAt          DateTime?
}

model ActivityLog {
  id           String    @id @default(uuid())
  user         User?     @relation(fields: [userId], references: [id])
  userId       String?
  eventType    String
  ipAddress    String?
  userAgent    String?
  resourceType String?
  resourceId   String?
  metadata     Json?     @db.JsonB
  createdAt    DateTime  @default(now())
}
